# PostgreSQL connection string (required for Vercel / production)
# Get one free at https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# SMTP email configuration (required for contact form notifications)
# Gmail example — use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Where to send contact form notifications (defaults to SMTP_USER if not set)
NOTIFICATION_EMAIL="ceo@formandframe.com"
