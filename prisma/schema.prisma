generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("team_member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String   @default("")
  linkUrl     String   @default("")
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Stat {
  id    String @id @default(cuid())
  label String
  value String
  order Int    @default(0)
}
